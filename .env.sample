# 環境変数の定義一覧。新規追加時は必ず本ファイルも更新する(policy #13)
COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
COSMOS_DATABASE=<database-name>
AI_PROJECT_ENDPOINT=https://<project>.services.ai.azure.com/api/projects/<name>
AI_DEPLOYMENT=<deployment-name>
USER_CTX_SECRET=<ランダムな長い文字列>
USER_CTX_TTL_SECONDS=3600
# ローカル(http)では false にする。本番は設定しない(既定 true)
COOKIE_SECURE=false
